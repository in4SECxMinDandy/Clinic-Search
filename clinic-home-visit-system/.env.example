# Environment variables for development
# Copy to .env and customize

# JWT Configuration
JWT_SECRET=changeme-in-production-use-openssl-rand-hex-32
JWT_ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=15
REFRESH_TOKEN_EXPIRE_DAYS=7

# Database
DATABASE_URL=postgresql://postgres:postgres@localhost:5432/postgres
REDIS_URL=redis://localhost:6379/0

# Service URLs (for Docker, use service names)
AUTH_SERVICE_URL=http://localhost:8003
CLINIC_SERVICE_URL=http://localhost:8001
BOOKING_SERVICE_URL=http://localhost:8002
REVIEW_SERVICE_URL=http://localhost:8004
NOTIFICATION_SERVICE_URL=http://localhost:8005

# SMTP Configuration (for email)
SMTP_HOST=smtp.mailtrap.io
SMTP_PORT=1025
SMTP_USER=
SMTP_PASSWORD=

# Frontend URL (for CORS)
FRONTEND_URL=http://localhost:3000

# Traefik
TRAEFIK_DASHBOARD_PORT=8080
